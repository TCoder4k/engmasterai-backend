# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated exact origins (scheme://host[:port], no path/query/
# fragment, never a wildcard — credentials are always enabled). Required in
# production; defaults to http://localhost:5174 in development/test if unset.
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Only set this if the app runs behind a real reverse proxy/load balancer.
# "false" (default) = trust nothing, use the raw socket IP. Otherwise a
# positive hop count (e.g. "1") or a specific trusted proxy IP/CIDR — never
# "true" (trusts every hop unconditionally). Governs Express's req.ip, which
# every rate-limit/IP-based check below reads — never a hand-parsed
# X-Forwarded-For header.
TRUST_PROXY=false

# JWT
JWT_SECRET=your-secret-key
JWT_EXPIRATION=1d

# Redis (session/refresh-token store — see docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
# Alternative to REDIS_HOST/REDIS_PORT: a single connection string, takes
# precedence over the two above if set.
# REDIS_URL=redis://localhost:6379

# Refresh tokens
REFRESH_TOKEN_TTL_SECONDS=2592000

# Auth rate limiting (Sprint 01C) — fixed-window counters, atomic via Redis
# (see src/auth/lua/rate-limit-incr.lua). Every endpoint below evaluates
# multiple buckets together (see docs/memory.md's Sprint 01C entry for the
# full key design and rationale); a request is rejected (429) if any bucket
# is exceeded.
AUTH_LOGIN_RATE_LIMIT_MAX=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_IP_RATE_LIMIT_MAX=20

AUTH_REGISTER_RATE_LIMIT_MAX=3
AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=3600
AUTH_REGISTER_EMAIL_RATE_LIMIT_MAX=5

AUTH_REFRESH_RATE_LIMIT_MAX=10
AUTH_REFRESH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_REFRESH_IP_RATE_LIMIT_MAX=30

# Google Sign-In (Sprint 02A) — off by default; the whole app boots normally
# with zero Google config. Set GOOGLE_AUTH_ENABLED=true AND GOOGLE_CLIENT_ID
# to enable POST /auth/google and /auth/google/link — enabling without a
# client ID fails startup. GOOGLE_CLIENT_ID is not a secret (it's the OAuth
# client's public identifier, also used as VITE_GOOGLE_CLIENT_ID in the
# frontend) — never put a Google *client secret* here or anywhere else in
# this app; none is required for the ID-token verification flow this app uses.
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Pre-verification IP-only limiting on both Google endpoints (an unverified
# JWT claim is attacker-chosen, never used as a rate-limit key — see
# docs/adr/004-google-auth.md). AUTH_GOOGLE_LINK_RATE_LIMIT_MAX guards a
# second, identity-keyed bucket checked inside AuthService.linkGoogle()
# itself, after the credential is verified — /auth/google/link is
# functionally a password-verification oracle and is rate-limited at least
# as strictly as login.
AUTH_GOOGLE_IP_RATE_LIMIT_MAX=30
AUTH_GOOGLE_RATE_LIMIT_WINDOW_SECONDS=60

AUTH_GOOGLE_LINK_IP_RATE_LIMIT_MAX=20
AUTH_GOOGLE_LINK_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_GOOGLE_LINK_RATE_LIMIT_MAX=5

# Transactional email + email verification (Sprint 02B) — off by default;
# the whole app boots with zero mail configuration and both new
# /auth/email-verification/* endpoints fail closed rather than attempting a
# real provider request. Set EMAIL_ENABLED=true AND every var below to
# enable — enabling without them fails startup. EMAIL_PROVIDER_API_KEY is
# backend-only and must never be exposed to the frontend. FRONTEND_APP_URL
# is the canonical single application URL used to build links embedded in
# outgoing emails — distinct from CORS_ALLOWED_ORIGINS.
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=EngMasterAI
EMAIL_PROVIDER_API_KEY=your-resend-api-key
EMAIL_PROVIDER_TIMEOUT_MS=5000
FRONTEND_APP_URL=http://localhost:5174
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=30

# Resend: guard-level IP bucket + a service-level user-scoped bucket
# (checked inside AuthService.resendVerification()). Verify: guard-level IP
# bucket + a token-hash-prefix bucket (bounds repeated attempts against one
# specific link; brute-forcing the 256-bit token itself remains infeasible
# regardless).
AUTH_EMAIL_VERIFY_RESEND_USER_RATE_LIMIT_MAX=3
AUTH_EMAIL_VERIFY_RESEND_IP_RATE_LIMIT_MAX=10
AUTH_EMAIL_VERIFY_RESEND_RATE_LIMIT_WINDOW_SECONDS=900

AUTH_EMAIL_VERIFY_IP_RATE_LIMIT_MAX=30
AUTH_EMAIL_VERIFY_TOKEN_RATE_LIMIT_MAX=10
AUTH_EMAIL_VERIFY_RATE_LIMIT_WINDOW_SECONDS=900

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
