datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}




//// ===================== ENUMS =====================

enum UserRole {
  USER
  ADMIN
}

enum CourseType {
  GRAMMAR
  VOCABULARY
  LISTENING
}

enum LessonTaskType {
  VIDEO
  QUIZ
  ARRANGE
  TRUE_FALSE
}

enum TaskProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum PartOfSpeech {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PRONOUN
  PREPOSITION
  CONJUNCTION
  INTERJECTION
  DETERMINER
  PHRASE
  IDIOM
}

enum WordSource {
  ADMIN
  IMPORT
  AI
}

//// ===================== MODELS =====================
//
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String? // nullable: Google-only accounts (Sprint 02A) have no local password
  name      String
  avatarUrl String? //can be null
  role      UserRole @default(USER)

  totalPoints Int @default(0)
  level       Int @default(1)

  createdAt DateTime @default(now())
  // Set only when the backend has cryptographically verified email ownership
  // (currently: a successful Google ID-token verification with
  // email_verified=true, at account-creation or account-linking time).
  // Sprint 02A writes this field; nothing reads or branches on it yet — it
  // exists so a future local-email-verification sprint (02B) inherits
  // accurate data with no backfill guesswork. NULL for every pre-existing
  // local account, which is accurate: their email ownership was never
  // verified.
  emailVerifiedAt DateTime?

  taskProgress LessonTaskProgress[]
  identities   AuthIdentity[]

  @@map("users") //users dùng cho query sql , còn User dùng cho code
}

enum AuthProvider {
  GOOGLE
}

// One row per external identity provider linked to a User (Sprint 02A). A
// separate table (not googleId/provider columns on User) so one account can
// hold multiple provider identities without nullable-column sprawl as more
// providers are added later.
model AuthIdentity {
  id     String @id @default(uuid())
  userId String

  provider        AuthProvider
  providerSubject String // Google's `sub` claim — stable, opaque, never the email
  providerEmail   String // verified email at link time — audit trail only, never a login key

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("auth_identities")
}

model Course {
  id          String     @id @default(uuid())
  title       String
  type        CourseType
  description String
  thumbnail   String?
  isPublished Boolean    @default(false)

  createdAt DateTime @default(now())

  lessons Lesson[]

  @@map("courses")
}

model Lesson {
  id          String  @id @default(uuid())
  courseId    String
  title       String
  description String?
  notes       String?

  videoUrl              String?
  pdfUrl                String?
  audioUrl              String?
  videoDurationMinutes  Int?
  estimatedStudyMinutes Int?
  learningObjectives    String[] @default([])

  orderIndex  Int
  isPublished Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course       Course             @relation(fields: [courseId], references: [id])
  tasks        LessonTask[]
  vocabularies LessonVocabulary[]

  @@index([courseId])
  @@map("lessons")
}

model LessonTask {
  id         String         @id @default(uuid())
  lessonId   String
  type       LessonTaskType
  title      String
  content    Json
  points     Int
  orderIndex Int

  createdAt DateTime @default(now())

  lesson    Lesson               @relation(fields: [lessonId], references: [id])
  questions Question[]
  progress  LessonTaskProgress[]

  @@map("lesson_tasks")
}

model Question {
  id            String  @id @default(uuid())
  taskId        String
  content       String
  options       Json?
  correctAnswer Json
  explanation   String?
  audioUrl      String?
  imageUrl      String?
  orderIndex    Int

  task LessonTask @relation(fields: [taskId], references: [id])

  @@map("questions")
}
//Một user có thể có nhiều tiến độ làm bài
model LessonTaskProgress {
  id            String             @id @default(uuid())
  userId        String
  taskId        String
  status        TaskProgressStatus @default(NOT_STARTED)
  score         Int                @default(0)
  maxScore      Int
  attemptsCount Int                @default(0)
  completedAt   DateTime?

  user User       @relation(fields: [userId], references: [id]) //reference tham chiếu đến id của bảng tiến độ
  task LessonTask @relation(fields: [taskId], references: [id])

  @@unique([userId, taskId])
  @@map("lesson_task_progress")
}

model Vocabulary {
  id            String  @id @default(uuid())
  word          String
  pronunciation String?
  meaning       String
  example       String?
  audioUrl      String?
  imageUrl      String?
  partOfSpeech  String?
  level         Int

  createdAt DateTime @default(now())

  lessons LessonVocabulary[]

  @@map("vocabularies")
}

model LessonVocabulary {
  id         String @id @default(uuid())
  lessonId   String
  vocabId    String
  orderIndex Int

  lesson     Lesson     @relation(fields: [lessonId], references: [id])
  vocabulary Vocabulary @relation(fields: [vocabId], references: [id])

  @@unique([lessonId, vocabId])
  @@map("lesson_vocabularies")
}

model VocabLibrary {
  id          String   @id @default(uuid())
  name        String
  description String
  thumbnail   String?
  orderIndex  Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  decks VocabDeck[]

  @@map("vocab_libraries")
}

model VocabDeck {
  id          String     @id @default(uuid())
  libraryId   String
  name        String
  description String?
  thumbnail   String?
  cefrLevel   CefrLevel?
  orderIndex  Int
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  library   VocabLibrary    @relation(fields: [libraryId], references: [id])
  deckWords VocabDeckWord[]

  @@index([libraryId])
  @@map("vocab_decks")
}

model VocabWord {
  id           String       @id @default(uuid())
  text         String
  ipa          String?
  audioUrl     String?
  imageUrl     String?
  cefrLevel    CefrLevel?
  synonyms     String[]     @default([])
  antonyms     String[]     @default([])
  collocations String[]     @default([])
  wordFamily   String[]     @default([])
  source       WordSource   @default(ADMIN)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  meanings  VocabWordMeaning[]
  examples  VocabWordExample[]
  deckWords VocabDeckWord[]

  @@index([text])
  @@map("vocab_words")
}

model VocabWordMeaning {
  id           String        @id @default(uuid())
  wordId       String
  partOfSpeech PartOfSpeech?
  meaning      String
  orderIndex   Int
  createdAt    DateTime      @default(now())

  word VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@map("vocab_word_meanings")
}

model VocabWordExample {
  id          String   @id @default(uuid())
  wordId      String
  sentence    String
  translation String?
  orderIndex  Int
  createdAt   DateTime @default(now())

  word VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId])
  @@map("vocab_word_examples")
}

model VocabDeckWord {
  id         String   @id @default(uuid())
  deckId     String
  wordId     String
  orderIndex Int
  createdAt  DateTime @default(now())

  deck VocabDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  word VocabWord @relation(fields: [wordId], references: [id])

  @@unique([deckId, wordId])
  @@index([wordId])
  @@map("vocab_deck_words")
}
